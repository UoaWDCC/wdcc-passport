#!/usr/bin/env sh
set -eu

STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR)"

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

git diff --cached --name-only -z --diff-filter=ACMR \
  | xargs -0 pnpm exec prettier --write --ignore-unknown

git diff --cached --name-only -z --diff-filter=ACMR \
  | xargs -0 git add

LINT_FILES="$(printf '%s\n' "$STAGED_FILES" | grep -E '\.(cjs|js|jsx|mjs|ts|tsx)$' || true)"

if [ -n "$LINT_FILES" ]; then
  printf '%s\n' "$LINT_FILES" | xargs pnpm exec eslint --fix
  printf '%s\n' "$LINT_FILES" | xargs git add
fi

pnpm typecheck
